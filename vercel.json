{
  "cleanUrls": true,
  "build": {
    "env": {
      "UV_LINK_MODE": "copy"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/public/(.*)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "hello.pixelnproof.com"
        }
      ],
      "destination": "/brand/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pixelnproof.com"
        }
      ],
      "destination": "/main/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.pixelnproof.com"
        }
      ],
      "destination": "/main/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/brand",
      "has": [
        {
          "type": "host",
          "value": "pixelnproof.com"
        }
      ],
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/brand/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pixelnproof.com"
        }
      ],
      "destination": "/",
      "permanent": false
    }
  ]
}