{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "hello.pixelnproof.com"
                }
            ],
            "destination": "/brand.html"
        },
        {
            "source": "/contact",
            "destination": "/contact.html"
        },
        {
            "source": "/work",
            "destination": "/work.html"
        }
    ]
}