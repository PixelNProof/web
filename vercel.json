{
  "cleanUrls": true,
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/",
        "has": [
          {
            "type": "host",
            "value": "hello.pixelnproof.com"
          }
        ],
        "destination": "/brand/index.html"
      },
      {
        "source": "/(.*)",
        "has": [
          {
            "type": "host",
            "value": "hello.pixelnproof.com"
          }
        ],
        "destination": "/brand/index.html"
      }
    ],
    "afterFiles": [
      {
        "source": "/contact",
        "destination": "/contact.html"
      },
      {
        "source": "/work",
        "destination": "/work.html"
      }
    ]
  },
  "redirects": [
    {
      "source": "/brand",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/brand/(.*)",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/brand.html",
      "destination": "/",
      "permanent": false
    }
  ]
}