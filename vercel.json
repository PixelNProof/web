{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "hello.pixelnproof.com"
        }
      ],
      "destination": "/brand/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/main/$1"
    },
    {
      "source": "/",
      "destination": "/main/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/brand",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/brand/(.*)",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/main/(.*)",
      "destination": "/$1",
      "permanent": false
    }
  ]
}