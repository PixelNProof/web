{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "hello.pixelnproof.com"
        }
      ],
      "destination": "/brand/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pixelnproof.com"
        }
      ],
      "destination": "/main/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.pixelnproof.com"
        }
      ],
      "destination": "/main/$1"
    }
  ],
  "redirects": [
    {
      "source": "/brand",
      "has": [
        {
          "type": "host",
          "value": "pixelnproof.com"
        }
      ],
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/brand/(.*)",
      "has": [
        {
          "type": "host",
          "value": "pixelnproof.com"
        }
      ],
      "destination": "/",
      "permanent": false
    }
  ]
}